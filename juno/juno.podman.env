# Juno Podman environment
# Copy to juno.podman.env.local and set JUNO_GATEWAY_TOKEN (or use -e when running).
# This file can be used with:
#   JUNO_PODMAN_ENV=/path/to/juno.podman.env ./scripts/run-juno-podman.sh launch

# Required: gateway auth token. Generate with: openssl rand -hex 32
# Set this before running the container (or use run-juno-podman.sh which can generate it).
JUNO_GATEWAY_TOKEN=

# Optional: web provider (leave empty to skip)
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=

# Host port mapping (defaults; override if needed)
JUNO_PODMAN_GATEWAY_HOST_PORT=18789
JUNO_PODMAN_BRIDGE_HOST_PORT=18790

# Gateway bind (used by the launch script)
JUNO_GATEWAY_BIND=lan

# Optional: LLM provider API keys (for zero cost use Ollama locally or Groq free tier)
# OLLAMA_API_KEY=ollama-local
# GROQ_API_KEY=
