{
  "name": "@juno/memory-lancedb",
  "version": "2026.4.20",
  "description": "Juno LanceDB-backed long-term memory plugin with auto-recall/capture",
  "type": "module",
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@sinclair/typebox": "0.34.49",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@juno/plugin-sdk": "workspace:*"
  },
  "juno": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@juno/memory-lancedb",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.20"
    },
    "build": {
      "junoVersion": "2026.4.20"
    },
    "release": {
      "publishToJunoHub": true,
      "publishToNpm": true
    }
  }
}
