{
  "name": "@juno/qa-lab",
  "version": "2026.4.20",
  "private": true,
  "description": "Juno QA lab plugin with private debugger UI and scenario runner",
  "type": "module",
  "dependencies": {
    "@copilotkit/aimock": "1.14.3",
    "playwright-core": "1.59.1"
  },
  "devDependencies": {
    "@juno/plugin-sdk": "workspace:*",
    "juno": "workspace:*"
  },
  "peerDependencies": {
    "juno": ">=2026.4.20"
  },
  "peerDependenciesMeta": {
    "juno": {
      "optional": true
    }
  },
  "juno": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@juno/qa-lab",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.20"
    }
  }
}
