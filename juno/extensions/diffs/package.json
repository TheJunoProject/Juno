{
  "name": "@juno/diffs",
  "version": "2026.4.20",
  "private": true,
  "description": "Juno diff viewer plugin",
  "type": "module",
  "scripts": {
    "build:viewer": "bun build src/viewer-client.ts --target browser --format esm --minify --outfile assets/viewer-runtime.js"
  },
  "dependencies": {
    "@pierre/diffs": "1.1.15",
    "@pierre/theme": "0.0.29",
    "@sinclair/typebox": "0.34.49",
    "playwright-core": "1.59.1"
  },
  "devDependencies": {
    "@juno/plugin-sdk": "workspace:*"
  },
  "juno": {
    "bundle": {
      "stageRuntimeDependencies": true
    },
    "extensions": [
      "./index.ts"
    ]
  }
}
